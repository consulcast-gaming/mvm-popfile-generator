{
  "name": "mvm-popfile-creator",
  "version": "1.0.0",
  "description": "TF2 MvM Popfile Creator",
  "license": "AGPL-3.0",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron-dev": "vite build && electron .",
    "package": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.mvm.popfile-creator",
    "productName": "MvM Popfile Creator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "icon.png"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
